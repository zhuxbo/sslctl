# 环境变量 (包含敏感信息)
.env

# 构建产物
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# 测试
*.test
*.out
coverage.html
coverage.txt

# 依赖
vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# 构建的二进制文件
/sslctl

# 工作目录（运行时生成）
sslctl/

# Test artifacts (dynamically built by test scripts)
docker/test/**/sslctl
docker/test/**/mock-api
docker/test/mock-api/mock-api-linux-*
docker/test/reports/test-report*.md
build/test-report.md

# 版本文件（构建时生成）
version.json

# 签名密钥（由 build/generate-keys.sh 生成）
release-key.pem
release-key.pub
public_key.go
