# cert-deploy 本地发布配置
# 复制为 local-release.conf 并填写实际值

# ========================================
# Release 服务配置
# ========================================
# 本地 release 服务目录
RELEASE_DIR="/var/www/release/cert-deploy"

# 本地 release 服务 URL（用于生成下载链接）
RELEASE_URL="http://localhost:8888/cert-deploy"

# ========================================
# 可选配置
# ========================================
# 每个通道保留的版本数量（默认 5）
# KEEP_VERSIONS=5
