# 集成测试配置示例（复制为 .env 使用）
# 部署 API 地址，例如: https://example.com/api/deploy
TEST_API_URL=

# 部署 Token
TEST_API_TOKEN=

# 用于校验的域名，例如: *.example.com
TEST_API_DOMAIN=

# 允许写入型集成测试（调用 Update/Callback 接口）
# TEST_API_ALLOW_WRITE=1
# TEST_API_ALLOW_CALLBACK=1

# 更新接口的验证方式，默认 http
# TEST_API_METHOD=http

# 更新接口的域名列表（逗号分隔），不填则使用 API 返回的域名
# TEST_API_DOMAINS=example.com,*.example.com
